{
  "manifest_version": 3,
  "name": "Collection Platform",
  "version": "4.0.0",
  "version_name": "4.0.0 — Knowledge Acquisition Runtime",
  "description": "Adapter-driven Knowledge Acquisition Runtime with the Discord production reference adapter.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://discord.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://discord.com/*"
      ],
      "js": [
        "src/core/namespace.js",
        "src/core/config.js",
        "src/platform/host/browser-extension-host.js",
        "src/platform/adapter-registry.js",
        "src/platform/detection-engine.js",
        "src/platform/discovery-framework.js",
        "src/platform/runtime-policies.js",
        "src/platform/collection-intent.js",
        "src/platform/mission-profile.js",
        "src/platform/knowledge-object.js",
        "src/platform/ui-translator.js",
        "src/platform/platform-runtime.js",
        "src/core/contracts/adapter-contract.js",
        "src/core/sdk/conversation-sdk.js",
        "src/core/diagnostics/logger.js",
        "src/adapters/discord/selectors.js",
        "src/core/cache.js",
        "src/core/profiles/profiles.js",
        "src/adapters/discord/discovery.js",
        "src/adapters/discord/topology.js",
        "src/adapters/discord/navigation.js",
        "src/adapters/discord/parser.js",
        "src/core/identity.js",
        "src/adapters/discord/collector.js",
        "src/adapters/discord/adapter-manifest.js",
        "src/adapters/discord/register.js",
        "src/core/acquisition/acquisition.js",
        "src/core/conversation-model.js",
        "src/core/topology-model.js",
        "src/core/renderers/json.js",
        "src/core/renderers/markdown.js",
        "src/core/renderers/topology-json.js",
        "src/core/renderers/topology-markdown.js",
        "src/core/exporter.js",
        "src/core/topology-exporter.js",
        "src/core/orchestration/batch.js",
        "src/core/diagnostics/validation.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Collection Platform"
  }
}
